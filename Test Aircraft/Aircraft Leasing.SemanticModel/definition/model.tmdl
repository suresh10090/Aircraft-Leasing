model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-GB
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["DimAircraft","DimLessee","FactLeaseMetrics"]

annotation PBI_ProTooling = ["DevMode"]

ref table DimAircraft
ref table DimLessee
ref table FactLeaseMetrics
ref table DimDate

ref cultureInfo en-US

