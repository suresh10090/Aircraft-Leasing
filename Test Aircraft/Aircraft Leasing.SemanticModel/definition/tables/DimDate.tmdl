	partition DimDate = calculated
		mode: import
		source = ```
				
				-- 1. Define the boundary dates based on our leasing portfolio history
				VAR MinYear = 2024
				VAR MaxYear = 2027
				VAR BaseCalendar = 
				    CALENDAR(
				        DATE(MinYear, 1, 1), 
				        DATE(MaxYear, 12, 31)
				    )
				RETURN
				    ADDCOLUMNS(
				        BaseCalendar,
				        -- The Integer Key used to join with FactLeaseMetrics[DateKey] (e.g., 20260520)
				        "DateKey", INT(FORMAT([Date], "YYYYMMDD")),
				        "Year", YEAR([Date]),
				        "Month Number", MONTH([Date]),
				        -- Short month format for clean dashboard visuals (e.g., "Jan")
				        "Month Short", FORMAT([Date], "MMM"),
				        "Month Long", FORMAT([Date], "MMMM"),
				        "Quarter", "Q" & FORMAT([Date], "Q"),
				        "Year Quarter", FORMAT([Date], "YYYY") & " Q" & FORMAT([Date], "Q"),
				        "Year Month", FORMAT([Date], "YYYY-MM"),
				        -- For sorting month text chronologically instead of alphabetically
				        "Year Month Sort", INT(FORMAT([Date], "YYYYMM")),
				        "Day of Week Number", WEEKDAY([Date], 2), -- 1 = Monday, 7 = Sunday
				        "Day of Week", FORMAT([Date], "DDDD")
				    )
				```

	annotation PBI_Id = 5026e141a3214cd297e3494c1fb3f3b3

